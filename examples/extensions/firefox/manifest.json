{
  "manifest_version": 3,
  "name": "WebExtension DB Firefox Example",
  "description": "Stores extension settings with webextension-db and browser.storage.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_title": "WebExtension DB"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "webextension-db-firefox-example@example.com"
    }
  }
}
