{
  "manifest_version": 3,
  "name": "WebExtension DB Safari Example",
  "description": "Stores extension settings with webextension-db and IndexedDB.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WebExtension DB"
  }
}
